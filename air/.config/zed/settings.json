// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "new_window",
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "right"
  },
  "context_servers": {
    "nyc-schools-local": {
      "enabled": true,
      "url": "http://127.0.0.1:8000/mcp/"
    },
    "duckdb": {
      "enabled": true,
      "remote": false,
      "command": "uvx",
      "args": [
        "mcp-server-motherduck",
        "--db-path",
        ":memory:",
        "--read-write",
        "--allow-switch-databases"
      ],
      "env": {}
    }
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    }
  },
  "project_panel": {
    "dock": "right"
  },
  "vim_mode": true,
  "agent": {
    "dock": "left",
    "tool_permissions": {
      "tools": {
        "fetch": {
          "default": "allow"
        }
      }
    },
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "gpt-4.1"
    },
    "default_profile": "write",
    "default_model": {
      "provider": "lmstudio",
      "model": "google/gemma-4-e2b"
    },
  },
  "ui_font_size": 15,
  "buffer_font_size": 12,
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Night Owl Dark"
  },
  "languages": {
    "Nix": {
      "tab_size": 2
    },
    "JavaScript": {
      "tab_size": 2
    },
    "TypeScript": {
      "tab_size": 2
    },
    "Svelte": {
      "tab_size": 2
    },
    "HTML": {
      "tab_size": 2
    },
    "CSS": {
      "tab_size": 2
    }
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 500
    }
  }
}
