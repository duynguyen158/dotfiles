// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "right"
  },
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "right"
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    }
  },
  "context_servers": {
    "figma": {
      "settings": {},
        
      "enabled": true,
      "url": "http://127.0.0.1:3845/mcp"
    },
    "bigquery": {
      "enabled": true,
      "remote": false,
      "command": "/opt/homebrew/bin/toolbox",
      "args": [
        "--prebuilt",
        "bigquery",
        "--stdio"
      ],
      "env": {
        "BIGQUERY_PROJECT": "newsroom-genai-dev"
      }
    }
  },
  "vim_mode": true,
  "agent": {
    "dock": "left",
    "tool_permissions": {
      "tools": {
        "fetch": {
          "default": "allow"
        },
        "mcp:bigquery:search_catalog": {
          "default": "allow"
        },
        "mcp:bigquery:list_table_ids": {
          "default": "allow"
        },
        "mcp:bigquery:ask_data_insights": {
          "default": "allow"
        },
        "mcp:bigquery:analyze_contribution": {
          "default": "allow"
        },
        "mcp:bigquery:execute_sql": {
          "default": "allow"
        },
        "terminal": {
          "default": "allow",
          "always_allow": [
            {
              "pattern": "^docker\\s+context(\\s|$)"
            }
          ]
        },
        "mcp:bigquery:get_table_info": {
          "default": "allow"
        }
      }
    },
    "inline_assistant_model": {
      "provider": "openai",
      "model": "gpt-4.1"
    },
    "default_profile": "write",
    "default_model": {
      "enable_thinking": false,
      "provider": "openai",
      "model": "gpt-5.5"
    }
  },
  "ui_font_size": 15,
  "buffer_font_size": 12,
  "theme": {
    "mode": "system",
    "light": "Catppuccin Latte",
    "dark": "Night Owl Dark"
  },
  "languages": {
    "Nix": {
      "tab_size": 2
    },
    "JavaScript": {
      "tab_size": 2
    },
    "TypeScript": {
      "tab_size": 2
    },
    "Svelte": {
      "tab_size": 2
    },
    "HTML": {
      "tab_size": 2
    },
    "CSS": {
      "tab_size": 2
    },
    "GraphQL": {
      "tab_size": 2
    }
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 500
    }
  },
  "soft_wrap": "editor_width"
}
